!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!

! FINLAND TRIP Dec 2025
! Modified Jan 2026 to use more physical parameter values.
! 3 layer geometry: ice, 'filler', bedrock.
! Built from geometry_Stokes_slide_transient.sif (I think).

!check keywords warn
!echo on master
$namerun = "InitialT1"
!$restart = ""
$element="p:1 -tri b:1 -quad b:3"
$directsolver="MUMPS"
!$directsolver="UMFPACK"
$fssaflag="full"
$adapTol = 1.0e-2


!---LUA BEGIN
! assert(loadfile('coupled.lua'))()
!---LUA END

!---LUA BEGIN
! assert(loadfile('parameters.lua'))()
!---LUA END

Header
  Mesh DB "footprint" ""
  Results Directory "VTUs/InitialT1"
End


!---------------------------------------------------
!---------------- CONSTANTS ------------------------
!---------------------------------------------------

Constants
  Gravity Norm = Real #gravity
  Fresh Water Density = Real #rhow
  Water Density = Real #rhow
  Ice Density = Real #rhoi
  Rock Density = Real #rhorock
  Gravity(4) = 0 0 -1 #gravity
  Stefan Boltzmann = Real 6.78E-08
  Reference Temperature = Real 273.15
  Reference Pressure = Real #p0
  !Gas Constant = Real 8.3145
  !Avogadro Number = Real 6.022140857E23
  Sea Level = Real 0.0

  !!!! Ignore Sea Spring Timestep, seems to be more stable without
  !Sea Spring Timestep Size = Real #1/yearindays !#yearinsec!/yearindays !!!!! makes huge difference for shelf velocity
  ! probably smart to use same timestep as in transient simulation later 
End

!---------------------------------------------------
!---------------- SIMULATION -----------------------
!---------------------------------------------------

Simulation
  Coordinate System  = "Cartesian 3D" 
  Simulation Type = "transient"
 
  Steady State Max Iterations = 20
  Steady State Min Iterations = 1

  Timestepping Method = "bdf"
  BDF Order = 1

  !! Small initial timesteps for initial adjustment
  Timestep Intervals(4) = 5 5 5 100
  Output Intervals(4) = 5 5 5 10
  Timestep Sizes(4) = Real 1e3 1e4 1e5 1e6


  !Timestep Intervals = 1
  !Output Intervals = 1
  !Timestep Sizes = 1

  
  Extruded Mesh Levels = Integer 51
  Preserve Baseline =  Logical True
  !Preserve Edges = Logical True 
  ! Extruded Mesh Ratio = 100

  ! Values for mesh density copied from MLB example
  Extruded Mesh Density = Variable Coordinate 3
     Real
     0.0 1
     0.5 0.003
    0.51 0.1
     1.0  0.5
   End
  Extruded BC Layers(2) = Integer 28 29
  Extruded Baseline Layer = Integer 3

  Post File = "$namerun$.vtu"
  Output File = "$namerun$.result"

  Output Variable 1 = "W"
  Output Variable 2 = "Velocity 1"
  Output Variable 3 = "Velocity 2"
  Output Variable 4 = "Velocity 3"
  Output Variable 5 = "Flow Solution Loads 1"
  Output Variable 6 = "Flow Solution Loads 2"
  Output Variable 7 = "Flow Solution Loads 3"
  Output Variable 8 = "Temperature"
  !Output Variable 9 = "Zs"
  !utput Variable 10 = "Zb"


  ! usually, Dirichlet BC's are initialized before everything else. Sometimes those 
  ! conditions are dependent on solutions of earlier solvers; next line ensures that
  ! this is not an issue.
  !-----------------------------------------
  Initialize Dirichlet Conditions = Logical False

  Restart File = "InitialVel.result"
  Restart Position = 0
  Restart Before Initial Condition = Logical False

! This is to do scaling for paraview before saving
!  vtu: Coordinate Scaling(3) = Real 1.0 20.0 20.0

! This is because the bug in paraview expat library
! Binary ok otherwise. 
  ascii output = logical true
  
! increasing will give more detailed output when running
  max output level = 3
End

!---------------------------------------------------
!---------------- BODIES ---------------------------
!---------------------------------------------------

! This body is located at the ice/bed interface and will be used to solve 
! the sheet equation

! Bedrock
Body 1
  Name = "bedrock"
  Equation = 1
  Body Force = 1
  Material = 1
  Initial Condition = 1
End

! Filler water layer
Body 2
  Name = "filler water"
  Equation = 2
  Body Force = 2
  Material = 2
  Initial Condition = 2
End

! the ice 
Body 3 !1
  Name = "ice"
  Equation = 3
  Body Force = 3
  Material = 3
  Initial Condition = 3
End

! the lower surface of ice
Body 4 !2
  Name = "interface"
  Body Force = 4
  Equation = 4
  Material = 3
  Initial Condition = 4
End

! The upper surface of ice
Body 5 !3
  Name = "top free surface"
  Equation = 5
  Material = 3
  Body Force = 5
  Initial Condition = 5
End

!---------------------------------------------------
!---------------- EQUATIONS ------------------------
!---------------------------------------------------
!---------------------------------------------------
Equation 1
  Name = "bedrock equation"
  Active Solvers(3) = 1 2 10 
  Convection = "none"
  !Convection = "Computed"
End

Equation 2
  Name = "filler equation"
  Active Solvers(3) = 1 2 10
  Convection = "none"
 !Convection = "Computed"

End

Equation 3
  Name = "ice equations"
  Active Solvers (7) = 1 2 3 6 8 9 10
  Convection = "None"

  Flow Solution Name = String "Flow Solution" 
End

Equation 4
  Name = "interface equations"
  Active Solvers(3) = 4 7 11
  !Convection = "Computed"                                       
  Flow Solution Name = String "Flow Solution"  
End
Equation 5
  Name = "freesurface equations"
  Active Solvers(1) = 5
  !Convection = "Computed"
  Flow Solution Name = String "Flow Solution" 
End

!---------------------------------------------------
!---------------- INITIAL CONDITIONS ---------------
!---------------------------------------------------
Initial Condition 1
  Bedrock = Variable Coordinate 1
    Real
      include "Initialisation/Dimensional_ICs/bed_dim.xy"
    End

    Temperature = Variable Coordinate 1
    Real 
      include "Initialisation/Dimensional_ICs/Tb_dim.xy"
    End
End

! For filler layer
Initial Condition 2
  Bedrock = Variable Coordinate 1
    Real
      include "Initialisation/Dimensional_ICs/bed_dim.xy"
    End
    Temperature = Variable Coordinate 1
    Real 
      include "Initialisation/Dimensional_ICs/Tb_dim.xy"
    End
End

! For ice
Initial Condition 3
  Bedrock = Variable Coordinate 1
    Real
      include "Initialisation/Dimensional_ICs/bed_dim.xy"
    End


    Temperature = Variable Coordinate 1
    Real 
      include "Initialisation/Dimensional_ICs/Tb_dim.xy"
    End
End

! For interface (ice lower surface)
Initial Condition 4
! import initial shape of bottom ice from file
    Zb = Variable Coordinate 1
    Real 
      include "Initialisation/Dimensional_ICs/zb_dim.xy"
    End
     refZb = Variable Coordinate 1
    Real 
      include "Initialisation/Dimensional_ICs/zb_dim.xy"
    End
   Bedrock = Variable Coordinate 1
    Real
      include "Initialisation/Dimensional_ICs/bed_dim.xy"
    End
  ! import initial groundedmask from file
   !groundedmask =  Variable "Coordinate 1"
    !  Real
    !  include "Initialisation/Dimensional_ICs/gm_dim.xy"
    ! End
End

! For ice top surface
Initial Condition 5
! import initial shape of surface from file
  Zs = Variable Coordinate 1
    Real 
      include "Initialisation/Dimensional_ICs/zs_dim.xy"
    End
End


!---------------------------------------------------
!---------------- BODY FORCES ----------------------
!---------------------------------------------------

! Bedrock
Body Force 1
  Name = "bodyforce bedrock"
  Partial Vertical MeshUpdate 1 = Real 0.0
  Partial Vertical MeshUpdate 2 = Real 0.0

  Temperature Upper Limit = Real 1000.0
  Temperature Lower Limit = Real 0.0
End

! Water filler
Body Force 2
  Name = "bodyforce filler"
  Partial Vertical MeshUpdate 1 = Real 0.0
  Partial Vertical MeshUpdate 2 = Real 0.0

  Temperature Upper Limit = Real 1000.0
  Temperature Lower Limit = Real 0.0
End

! Ice 
Body Force 3 !1
  Name = "bodyforce ice"
  Flow BodyForce 1 = Real 0
  Flow BodyForce 2 = Real 0
  Flow BodyForce 3 = Real #-gravity

  ! Deformational heating (from deformational heat solver)
  Volumetric Heat Source = Equals W

    !! Might not be enforced
  Temperature Upper Limit = Real 273.15 ! we ignore pressure melting point
  Temperature Lower Limit = Real 0.0  
End 

Body Force 4 !2
  Name = "bodyforce interface"
  Zb Accumulation = Real 0.0
 ! Zb Accumulation Condition = Opposes "GroundedMask"
 Flow Solver Name = String "Flow Solution"
 Temperature Upper Limit = Real 273.15
End

Body Force 5
  Name = "bodyforce freesurface"
  Zs Accumulation = Real #aDIM
  Temperature Upper Limit = Real 273.15
End



!---------------------------------------------------
!---------------- MATERIALS ------------------------
!---------------------------------------------------
! Bedrock material properties
Material 1
  Name = "bedrock material"
  Density = real #rhorock

  Heat Capacity = Real #heatcapacityrock
  Heat Conductivity = Real #heatconductivityrock
  Mesh Elastic Modulus = Real 100.0
  Mesh Poisson Ratio = Real 0.0
  

End


!Bedrock material properties
Material 2
  Name = "filler material"
  Density = real #rhorock

  Heat Capacity = Real #heatcapacityrock
  Heat Conductivity = Real #heatconductivityrock
  Mesh Elastic Modulus = Real 100.0
  Mesh Poisson Ratio = Real 0.0	

End


!! ice material properties in MPa - m - a system 
Material 3
  Name = "ice material"

  Density = Real #rhoi
  Viscosity = Real #viscosity 

  Relative Temperature = Variable Temperature
    Real Lua "tx[0] - 273.15"

  ! Thermo-mechanical coupling
  Heat Capacity Scaling Factor = Real 1.0
  Heat Conductivity Scaling Factor = Real 1.0
  Heat Capacity = Real #heatcapacity
  Heat Conductivity = Real #heatconductivity

  ! for the stress solver
  Cauchy = Logical True

  !Glen Allow Old Keywords = Logical True
  Temperature Field Variable = Temperature

  !Diffusion coefficient = Real #k 
  !Bedrock bump height = Real #hr 
  !Cavity spacing = Real #lr 

  Basal Velocity 1 = Equals Velocity 1
  Basal Velocity 2 = Equals Velocity 2
  Basal Velocity 3 = Equals Velocity 3

  !Phi0 = Variable "Stress 3", "Zb"   ! I THINK Stress 3 is the upward (z-direction) ice pressure, making the negative the ice overburden (downward) pressure
  !  Real LUA "-tx[0] + rhow*gravity*tx[1]"   ! 'reference' hydraulic potential
  
  Mesh Elastic Modulus = Real 100.0
  Mesh Poisson Ratio = Real 0.0
  
  !!Constraints to ensure shelf stability (probably not nescesarry)
  Min Zb = Equals "bedrock"
  Max Zb = Real 0.0
  Min Zs = Real 0.0
  Max Zs = Real 10000
  
  Temperature Upper Limit = Real 273.15

End




!---------------------------------------------------
!---------------- SOLVERS --------------------------
!---------------------------------------------------
!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!

!! Solvers 1 and 2 extrude the 2D footprint to a 3D mesh 
!! bounded by the surface at Zs in the top 
!! always execute before next timestep (shape may have changed)

Solver 1
  Equation = "MapCoordinateInit"
  Procedure = "StructuredMeshMapper" "StructuredMeshMapper"
  Minimum Height = Real 1.0
  Exec Solver = "Before Timestep"
  Active Coordinate = Integer 3
  Variable = -nooutput DummyR
  Mesh Velocity Variable = String "dSdt"
  Mesh Update Variable = String "dS"
  Mesh Velocity First Zero = Logical True
  Exported Variable 1 = -dofs 1 "dS"
  Exported Variable 2 = -dofs 1 "dSdt"
  Adjust Surface = Logical True
  Bubbles in global system = False
End

Solver 2
 Equation = "partial update"
 Procedure = "MeshSolve" "MeshSolver"
 Exec Solver = "Before Timestep"
 !Exec Solver = "never"
 Variable = -dofs 3 "Partial Vertical MeshUpdate"
 Linear System Solver = Iterative

 Linear System Iterative Method = BiCGStabL
 Linear System Preconditioning = ILU1
 Linear System Max Iterations = 500
 Linear System Convergence Tolerance = 1.0e-12
 Linear System Residual Output = 50

 Steady State Convergence Tolerance = 1.0e-5
 !Bubbles in global system = False
 Exported Variable 1 = -dofs 1 "bedrock"
 Update Exported Variables = True
End

! Computes height and depth assuming an extruded mesh.
Solver 3 
  Exec Solver = "before Timestep" 
  Equation = "HeightDepth"
  Procedure = "StructuredProjectToPlane" "StructuredProjectToPlane"
  Active Coordinate = Integer 3
  Operator 1 = depth
  Operator 2 = height
  Dot Product Tolerance = 1.0e-3
  !Bubbles in global system = False
End 

Solver 4
  Equation = "Free Surface Sea/Shelf"
  Exec Solver = "Never"
  ! Element = "p:1 -tri b:1 -quad b:3 -wedge b:1 -brick b:4"

 !Exec Solver = "After Timestep"
  Procedure =  "FreeSurfaceSolver" "FreeSurfaceSolver"
  Variable = "Zb"
  Variable DOFS =  1
  Exported Variable 1 = "Zb Residual"
  Exported Variable 1 DOFs = 1

  ! Before Linsolve = "EliminateDirichlet" "EliminateDirichlet"

  Linear System Solver = Iterative
  Linear System Max Iterations = 1500
  Linear System Iterative Method = BiCGStab
  Linear System Preconditioning = ILU0
  Linear System Convergence Tolerance = Real 1.0e-6
  Linear System Abort Not Converged = False
  Linear System Residual Output = 1

  Nonlinear System Max Iterations = 100
  Nonlinear System Convergence Tolerance  = 1.0e-3 !1.0e-5
  Nonlinear System Relaxation Factor = 1.00

  Steady State Convergence Tolerance = 1.0e-03

  Stabilization Method = Bubbles
  Apply Dirichlet = Logical True

  Relaxation Factor = Real 1.0

End

Solver 5
  Equation = "Free Surface Top"
  Exec Solver = "Never"
  ! Exec Solver = "Predictor-Corrector"
    !Element = "p:2 -tri b:1 -quad b:3 -wedge b:1 -brick b:4"

  !Exec Solver = "After Timestep"
  Procedure =  "SRC/FreeSurfaceSolver2.so" "FreeSurfaceSolver"
  Variable = "Zs"
  Variable DOFs =  1
  Exported Variable 1 = "Zs Residual"
  Exported Variable 1 DOFs = 1

  ! Before Linsolve = "EliminateDirichlet" "EliminateDirichlet"

  Linear System Solver = Iterative
  Linear System Direct Method = $directsolver
  Linear System Max Iterations = 1500
  Linear System Iterative Method = BiCGStab
  Linear System Preconditioning = ILU0
  Linear System Convergence Tolerance = Real 1.0e-6
  Linear System Abort Not Converged = False
  Linear System Residual Output = 1

  Nonlinear System Max Iterations = 100
  Nonlinear System Convergence Tolerance  = 1.0e-3 !1.0e-5
  Nonlinear System Relaxation Factor = 1.00

  Steady State Convergence Tolerance = 1.0e-03

  Stabilization Method = Bubbles
  Apply Dirichlet = Logical True

  Relaxation Factor = Real 1.0


End 

!! compute normal vectors
!! the surfaces on which to compute normals are specified in boundary conditions
Solver 6
   Exec Solver = "Before Timestep"
   Equation = "Normal vector"
   Variable = "Normal Vector"   
   ! in 3dimensional simulations we have 3 entries
   Variable DOFs = 3
   !NB: does not need to actually solve a matrix
   !    hence no BW optimization needed
   Optimize Bandwidth = Logical False 
   Procedure = "ElmerIceSolvers" "ComputeNormalSolver"
   ! if set to True, all boundary normals would be computed by default
   ComputeAll = Logical False
   Bubbles in global system = False
End

Solver 7
  Exec Solver = "Before Timestep"
  Equation = "GroundedMask"
  Procedure = "ElmerIceSolvers" "GroundedSolver"
  Variable = "GroundedMask"
  Variable DOFs = 1

  Toler = Real 1.0e-01
  Bedrock Variable = String "bedrock"
  Exported Variable 1 = -dofs 1 bedrock
  Bubbles in global system = False
End

!-------------------------
! the Stokes solver 
!------------------------
Solver 8
  Exec Solver = "Never"
  Equation = "Stokes-Vec"
  Procedure = "IncompressibleNSVec" "IncompressibleNSSolver"
  Div-Curl Discretization = Logical False
  Element = "p:1 -tri b:1 -quad b:3 -wedge b:1 -brick b:4"

  !Variable = -dofs 4 "Flow Solution" [Velocity:3 Pressure:1]

  Optimize Bandwidth = Logical True
  Flow Model = Stokes
  Stabilization Method = String Bubbles !Stabilized

  !Non-linear iteration settings:
  !------------------------------ 
  Nonlinear System Max Iterations = 10
  Nonlinear System Convergence Tolerance  = 1.0e-3 !1.0e-5
  Nonlinear System Newton After Iterations = 5
  Nonlinear System Newton After Tolerance = 1.0e-1
  Nonlinear System Relaxation Factor = #2/3

  Viscosity Newton Relaxation Factor = $2.0/3.0 
  !Nonlinear System Reset Newton = Logical True

  include  SRC/linsys/mumps.sif
  ! mumps or gcr? Sophie used mumps, MLB used gcr.

  ! Convergence on timelevel (not required here)
  !---------------------------------------------
  Steady State Convergence Tolerance = Real 1.0e-3

  !Relative Integration Order = -1
  Number of Integration Points = Integer 44 ! 21, 28, 44, 64, ...

  ! 1st iteration viscosity is constant
  !Constant-Viscosity Start = Logical True

  Calculate Loads = Logical True


  Bubbles in global system = False
  Exported Variable 1 = -dofs 4 Flow Solution Loads
End

!-----------------------------------------------------
! Deformational heat solver, add output to body force (since keyword "friction heat" is not included in HeatSolve-Vec)
!-----------------------------------------------------
Solver 9
  Exec Solver = "Never"

  Equation = DeformationalHeat
  Variable = W
  Variable DOFs = 1

  procedure =  "ElmerIceSolvers" "DeformationalHeatSolver"

  Linear System Solver = "Iterative"                                                                                              
  Linear System Iterative Method =  "GCR"     !"BICGStab"
  Linear System Max Iterations = 5000
  Linear System Convergence Tolerance = 1.0E-08
!  Linear System Abort Not Converged = False
  Linear System Preconditioning = "ILU1"
  Linear System Residual Output = 100
  Bubbles in global system = False
End

!-----------------------------------------------------
! Heat solver in ice
!-----------------------------------------------------
Solver 10
  !Exec Solver = "Never"
  Equation = String "Homologous Temperature Equation"
  Procedure =  File "HeatSolveVec" "HeatSolver"
  
  Variable = String "Temperature"
    Element = "p:1 -tri b:1 -quad b:3 -wedge b:1 -brick b:4"

  Number of Integration Points = Integer 64
  Optimize Bandwidth = Logical True
 Linear System Solver = "Direct"
 Linear System Direct Method = $directsolver

 !Linear System Solver = "Iterative"
 !Linear System Iterative Method = "GCR"
  Linear System GCR Restart = Integer 200
  Linear System Max Iterations = 15000
  Linear System Convergence Tolerance = 1.0E-08
  Linear System Abort Not Converged = True
  Linear System Preconditioning = "ILU1"
  Linear System Residual Output = 100
  Nonlinear System Convergence Tolerance = 1.0e-5 !1.0E-05
  Nonlinear System Max Iterations = 50
  Nonlinear System Min Iterations = 1
  Nonlinear System Relaxation Factor = Real 0.5
  Nonlinear System Convergence Measure = "solution"

  Steady State Convergence Tolerance = 1.0E-04
  Steady State Relaxation Factor = Real #1.0/3.0
  ! the contact algorithm (aka Dirichlet algorithm)
  !-----------------------------------------------------
  Stabilize = Logical True
  !Apply Limiter = Logical True
  Apply Limiter = Logical False

  !Save Limiter = Logical True
  Exported Variable 1 = -dofs 1 "Rel Temperature"
  Exported Variable 2 = -dofs 1 "Temperature Boundary Weights"

  ! those two variables are needed in order to store
  ! the relative or homologous temperature as well
  Update Exported Variables = Logical True
  Nonlinear Update Exported Variables = Logical True

  Nonlinear System Relaxation Before = Logical True

  Limiter Load Tolerance = Real 1.0e-6
  Limiter Value Tolerance = Real 1.0e-6
 
  Bubbles in global system = False

  !! we need the boundary weights for the computation of the basal shear stress 
  !! (divide flow solution loads by the boundary weights to get stress)
  !! (and then get shear stress using the normal vector)
  !! Keyword causes a segfault with the Stokes solver, therefore use it here
  !! since weights are purely geometrical it should not make a difference
  !Calculate Boundary Weights = Logical True
  !Calculate Loads = Logical True
End

Solver 11
  Equation = Fw
  exec solver = never
  Procedure = "ElmerIceSolvers" "GetHydrostaticLoads"
  Variable = Fw[Fwater:3]
  Variable DOFs = 3
End

!---------------------------------------------------
!---------------- BOUNDARY CONDITIONS --------------
!---------------------------------------------------

!! lowest numbers are those boundaries, that live in the original 2D mesh
!! assign the lower lines of the mesh = the sides of the footprint
!! to boundary conditions
!! target boundary numbers were defined in the mesh file


Boundary Condition 1
  Name = "inflow"
  Target Boundaries(1) = 1
End

Boundary Condition 2
  Name = "front"
  Target Boundaries(1) = 2
End

Boundary Condition 3
  Name = "side1"
  Target Boundaries(1) =  3
End

Boundary Condition 4
  Name = "side2"
  Target Boundaries(1) =  4
End

Boundary Condition 5
  Name = "inflow bedrock"
  Target Boundaries(1) = 5
  Partial Vertical MeshUpdate 1 = Real 0.0
  Partial Vertical MeshUpdate 2 = Real 0.0
  !Partial Vertical MeshUpdate 3 = Real 0.0  

!!Symmetry
  Temperature Flux BC = Logical True
  Heat Flux = Real 0.0 
End

Boundary Condition 6
  Name = "front bedrock"
  Target Boundaries(1) = 6
   Partial Vertical MeshUpdate 1 = Real 0.0
  Partial Vertical MeshUpdate 2 = Real 0.0
  !Partial Vertical MeshUpdate 3 = Real 0.0 
End

Boundary Condition 7
  Name = "side1 bedrock"
  Target Boundaries(1) =  7
  Partial Vertical MeshUpdate 1 = Real 0.0
  Partial Vertical MeshUpdate 2 = Real 0.0
  !Partial Vertical MeshUpdate 3 = Real 0.0  
End

Boundary Condition 8
  Name = "side2 bedrock"
  Target Boundaries(1) =  8
  Partial Vertical MeshUpdate 1 = Real 0.0
  Partial Vertical MeshUpdate 2 = Real 0.0
  !Partial Vertical MeshUpdate 3 = Real 0.0  
End

Boundary Condition 9
  Name = "inflow filler"
  Target Boundaries(1) = 9
  Partial Vertical MeshUpdate 1 = Real 0.0
  Partial Vertical MeshUpdate 2 = Real 0.0  
  Temperature Flux BC = Logical True
  Heat Flux = Real 0.0 
End

Boundary Condition 10
  Name = "front filler"
  Target Boundaries(1) = 10
  Partial Vertical MeshUpdate 1 = Real 0.0
  Partial Vertical MeshUpdate 2 = Real 0.0
    
End

Boundary Condition 11
  Name = "side1 filler"
  Target Boundaries(1) =  11
  Partial Vertical MeshUpdate 1 = Real 0.0
  Partial Vertical MeshUpdate 2 = Real 0.0  
End

Boundary Condition 12
  Name = "side2 filler"
  Target Boundaries(1) =  12
  Partial Vertical MeshUpdate 1 = Real 0.0
  Partial Vertical MeshUpdate 2 = Real 0.0
End

Boundary Condition 13
 Name = "inflow ice"
 Target Boundaries(1) = 13
  
! save the values of the fields at this boundary
  Save Line = Logical True

  Velocity 1 = 0.0 ! symmetry condition
  Velocity 2 = 0.0

  Partial Vertical MeshUpdate 1 = Real 0.0
  Partial Vertical MeshUpdate 2 = Real 0.0
  Partial Vertical MeshUpdate 3 = Real 0.0

!!Symmetry
  Temperature Flux BC = Logical True
  Heat Flux = Real 0.0 
End


Boundary Condition 14
  Name = "front ice"
  Target Boundaries(1) = 14
  Velocity 2 = 0.0
  Flow Force BC = Logical True
  External Pressure = Variable Coordinate 3
      Real Procedure "SRC/Buoyancy.so" "SeaPressure"
  Compute Sea Pressure = Logical True

  Partial Vertical MeshUpdate 1 = Real 0.0
  Partial Vertical MeshUpdate 2 = Real 0.0 
   
  !!Prevents shelf blow up
  ComputeNormal = Logical False
End
!! since the lines of the footprint were assigned to the first 3 BC
!! the next 3 BC describe the sides of the ice which go up from the footprint lines

Boundary Condition 15
! save the values of the fields at this boundary
! due to symmetry (no variation of fields along y direction) this should enable to plot values along lines in z direction
  Save Line = Logical True
  Target Boundaries(1) = 15
  Name="side1 ice"
  Velocity 2 = 0.0
  Partial Vertical MeshUpdate 1 = Real 0.0
  Partial Vertical MeshUpdate 2 = Real 0.0
  Partial Vertical MeshUpdate 3 = Real 0.0
End

Boundary Condition 16
  Name="side2 ice"
  Target Boundaries(1) = 16
  Velocity 2 = 0.0
  Partial Vertical MeshUpdate 1 = Real 0.0
  Partial Vertical MeshUpdate 2 = Real 0.0
  Partial Vertical MeshUpdate 3 = Real 0.0
End

!! the last boundary conditions are top and bottom which are still left
!! the order of the three following boundaries is important
!! first the bed, then bed-sediment followed by glacier bed  and then the surface
!! they have to come after the last targeted boundary (from the mesh.boundary file)

Boundary Condition 17
  Name = "deep bedrock"

  Partial Vertical MeshUpdate 1 = Real 0.0
  Partial Vertical MeshUpdate 2 = Real 0.0
  Partial Vertical MeshUpdate 3 = Real 0.0
  Bottom Surface = Variable "bedrock"
     Real LUA "tx[0] -  10*zscale"

  Temperature Flux BC = Logical True
    Heat Flux = Real #gthf
End

Boundary Condition 18
  Name = "bedrock - filler"
 ! bedrock = Variable Coordinate 1
 !     Real cubic
 !     include "./bed_new.xy"
  ! Adjust the position of the boundary so that it lies on the bedrock.

  Partial Vertical MeshUpdate 1 = Real 0.0
  Partial Vertical MeshUpdate 2 = Real 0.0
  Partial Vertical MeshUpdate 3 = Variable "Coordinate 3", "bedrock"
    Real LUA "tx[1] - tx[0] - minh"
  ! Impose T = Tm on at the bottom of the ocean (otherwise, natural BC - i.e. continuous heat flux)
  Temperature = Variable Coordinate 1
    Real 
      include "Initialisation/Dimensional_ICs/Tb_dim.xy"
    End
  End

Boundary Condition  19
  Name = "interface"  
  Body ID = 4
 
  !Zb = Equals bedrock
  !Zb Condition = Variable GroundedMask
   ! Real MATC "tx[0] + 0.5"
 
  Mid Surface  = Equals "Zb"
 
  Normal-Tangential Velocity = Logical True

  Velocity 1 = 0.0
 
  Velocity 1 Condition = Variable "GroundedMask"  
      Real MATC "tx[0] + 0.5"


  Flow Solution Name = String "Flow Solution" 

  Slip Coefficient 1 = Variable "time"
    Real Procedure "SRC/Buoyancy.so" "SeaSpring"   ! Buoyancy.f90 (and .so) have been modified to use body 3 (ice) instead of default body 1
  Compute Sea Spring = Logical True
  
  Slip Coefficient 2 = Variable Coordinate 1
    Real Procedure "ElmerIceUSF" "SlidCoef_Contact"
  
  Slip Coefficient 3 = Variable Coordinate 1
    Real Procedure "ElmerIceUSF" "SlidCoef_Contact"
  
  External Pressure = Variable Coordinate 3
    Real Procedure "SRC/Buoyancy.so" "SeaPressure"
  Compute Sea Pressure = Logical True

  ComputeNormal Condition = Variable GroundedMask
      Real MATC "tx[0] + 0.5"

  Grounding Line Moves = Logical True
  Grounding Line Definition = String "Discontinuous"
  Test Contact Tolerance = Real 1E-3

  ! SLIDING LAW
  Sliding Law = String Weertman
  Weertman Exponent = Real 1.0
  Weertman Friction Coefficient = Variable Temperature
   Real lua "TDepSlidingExp(fcoeff,tx[0],dT)"
  Weertman Linear Velocity = Real 1.0E-10

  Partial Vertical MeshUpdate 1 = Real 0.0
  Partial Vertical MeshUpdate 2 = Real 0.0
  Partial Vertical MeshUpdate 3 = Real 0.0
  !Partial Vertical MeshUpdate 3 = Variable "Coordinate 3", "Zb"
  !  Real LUA "tx[1] - tx[0]"

  !!!   Dirichlet Steady State Temperature Condition
  !Temperature = Variable Coordinate 1
  !  Real 
  !    include "Initialisation/Dimensional_ICs/Tb_dim.xy"
  !  End
  
  !!!  OR use frictional heating neumann condition
  Temperature = Real 273.15
  Temperature Condition = Variable "GroundedMask"    ! only apply temperature BC on ungrounded ice
      Real Lua "-1*tx[0]"
  Temperature Flux BC = Logical True
  Heat Flux = Real 0.0
  Heat Flux Condition = Variable "GroundedMask"    ! only apply temperature BC on ungrounded ice
      Real Lua "tx[0]+0.5"

  Friction Loads = Variable Flow Solution Loads 1, Flow Solution Loads 2, Flow Solution Loads 3, Velocity 1, Velocity 2, Velocity 3
    Real Lua "frictionloads(tx[0],tx[1],tx[2],tx[3],tx[4],tx[5])"
  Temperature Load = Variable Flow Solution Loads 1, Flow Solution Loads 2, Flow Solution Loads 3, Velocity 1, Velocity 2, Velocity 3
    Real Lua "frictionloads(tx[0],tx[1],tx[2],tx[3],tx[4],tx[5])"
  
  Calculate Temperature Boundary Weights = Logical True

  FSSA Theta = Real 1.0 
  FSSA Flag = String $fssaflag
  FSSA Accumulation = Real 0.0
End

Boundary Condition 20
  Name = "free surface"
  Top Surface = Equals "Zs"
  Body ID = 5
  Temperature = Real #Tsurf ! -10 degrees
  !Body Id = 5
  ComputeNormal = Logical True

  Partial Vertical MeshUpdate 1 = Real 0.0
  Partial Vertical MeshUpdate 2 = Real 0.0
  Partial Vertical MeshUpdate 3 = Real 0.0

  FSSA Theta = Real 1.0  
  FSSA Flag = String $fssaflag
  FSSA Accumulation = Real #aDIM
End
